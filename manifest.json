{
  "manifest_version": 3,
  "name": "ExportChat",
  "version": "1.0.0",
  "description": "Export any AI chat to MD, PDF, TXT, HTML, JSON. Free. Unlimited. Works on ChatGPT, Claude, Gemini and Perplexity.",
  "permissions": [],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": [
        "libs/turndown.js",
        "libs/jspdf.min.js",
        "export/markdown.js",
        "export/pdf.js",
        "export/text.js",
        "export/html.js",
        "export/json.js",
        "ui/button.js",
        "content/claude.js"
      ],
      "css": ["ui/button.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chat.openai.com/*", "https://chatgpt.com/*"],
      "js": [
        "libs/turndown.js",
        "libs/jspdf.min.js",
        "export/markdown.js",
        "export/pdf.js",
        "export/text.js",
        "export/html.js",
        "export/json.js",
        "ui/button.js",
        "content/chatgpt.js"
      ],
      "css": ["ui/button.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": [
        "libs/turndown.js",
        "libs/jspdf.min.js",
        "export/markdown.js",
        "export/pdf.js",
        "export/text.js",
        "export/html.js",
        "export/json.js",
        "ui/button.js",
        "content/gemini.js"
      ],
      "css": ["ui/button.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.perplexity.ai/*", "https://perplexity.ai/*"],
      "js": [
        "libs/turndown.js",
        "libs/jspdf.min.js",
        "export/markdown.js",
        "export/pdf.js",
        "export/text.js",
        "export/html.js",
        "export/json.js",
        "ui/button.js",
        "content/perplexity.js"
      ],
      "css": ["ui/button.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "ExportChat",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
